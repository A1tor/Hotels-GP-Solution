<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Таблица Hotel -->
    <changeSet id="1" author="developer">
        <createTable tableName="hotel">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(255)"/>
            <column name="brand" type="VARCHAR(255)"/>
            <column name="house_number" type="VARCHAR(255)"/>
            <column name="street" type="VARCHAR(255)"/>
            <column name="city" type="VARCHAR(255)"/>
            <column name="country" type="VARCHAR(255)"/>
            <column name="post_code" type="VARCHAR(255)"/>
            <column name="phone" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="check_in" type="VARCHAR(255)"/>
            <column name="check_out" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <!-- Таблица AmenityList -->
    <!-- Основная таблица сущности -->
    <changeSet id="2" author="developer">
        <createTable tableName="amenity_list">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Таблица для хранения List<String> amenities из класса AmenityList -->
    <!-- Так как JPA не может хранить List<String> в одной колонке без @Lob/JSON,
         обычно создается таблица связи для элемент-коллекции -->
    <changeSet id="3" author="developer">
        <createTable tableName="amenity_list_items">
            <column name="amenity_list_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_al_items_to_al" referencedTableName="amenity_list" referencedColumnNames="id"/>
            </column>
            <column name="amenity_value" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <!-- Индекс для порядка списка, если важно, или просто для наличия -->
            <column name="item_order" type="INT"/>
        </createTable>
    </changeSet>

    <!-- Таблица Amenity -->
    <changeSet id="4" author="developer">
        <createTable tableName="amenity">
            <column name="name" type="VARCHAR(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Таблица для хранения Set<Long> hotels из класса Amenity -->
    <!-- Связь Amenity -> Hotel (многие ко многим или элемент-коллекция ID) -->
    <changeSet id="5" author="developer">
        <createTable tableName="amenity_hotels">
            <column name="amenity_name" type="VARCHAR(255)">
                <constraints nullable="false" foreignKeyName="fk_ah_to_amenity" referencedTableName="amenity" referencedColumnNames="name"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_ah_to_hotel" referencedTableName="hotel" referencedColumnNames="id"/>
            </column>
        </createTable>

        <!-- Уникальный индекс, чтобы избежать дубликатов в Set -->
        <addUniqueConstraint tableName="amenity_hotels" columnNames="amenity_name, hotel_id" constraintName="uq_amenity_hotel_pair"/>
    </changeSet>

</databaseChangeLog>